+---
+import { getCollection } from 'astro:content';
+import FormattedDate from '../../../components/FormattedDate.astro';
+import { PRODUCTS, SUBCATEGORIES } from '../../../consts';
+import BaseLayout from '../../../layouts/BaseLayout.astro';
+
+const product = PRODUCTS.find((p) => p.slug === 'epm-cloud-updates')!;
+const subcategory = SUBCATEGORIES.find((s) => s.slug === 'latest-release')!;
+const articles = (
+	await getCollection(
+		'articles',
+		({ data }) => data.product === 'epm-cloud-updates' && data.subcategory === 'latest-release',
+	)
+).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
+---
+
+<BaseLayout
+	title={`${subcategory.name} - ${product.name} - Oracle EPM Cloud Blog`}
+	description={`${subcategory.description} for ${product.name}`}
+>
+	<nav class="breadcrumb">
+		<a href="/">Home</a> &rsaquo;
+		<a href={`/${product.slug}/`}>{product.name}</a> &rsaquo;
+		<span>{subcategory.name}</span>
+	</nav>
+
+	<h1>{subcategory.name}</h1>
+	<p>{subcategory.description} for {product.name}.</p>
+
+	<nav class="subcategory-nav">
+		{SUBCATEGORIES.map((sub) => (
+			<a
+				href={`/${product.slug}/${sub.slug}/`}
+				class:list={[{ active: sub.slug === subcategory.slug }]}
+			>
+				{sub.name}
+			</a>
+		))}
+	</nav>
+
+	{articles.length > 0 ? (
+		<ul class="article-list">
+			{articles.map((article) => (
