---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { PRODUCTS, SUBCATEGORIES } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';

const product = PRODUCTS.find((p) => p.slug === 'narrative-reporting')!;
const articles = (await getCollection('articles', ({ data }) => data.product === 'narrative-reporting')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`${product.name} - Oracle EPM Cloud Blog`} description={product.description}>
	<h1>{product.name}</h1>
	<p>{product.description}</p>

	<nav class="subcategory-nav">
		{SUBCATEGORIES.map((sub) => (
			<a href={`/${product.slug}/${sub.slug}/`}>{sub.name}</a>
		))}
	</nav>

	{articles.length > 0 ? (
		<ul class="article-list">
			{articles.map((article) => {
				const sub = SUBCATEGORIES.find((s) => s.slug === article.data.subcategory);
				return (
					<li>
						<a href={`/${product.slug}/${article.data.subcategory}/${article.id}/`}>
							<span class="article-title">{article.data.title}</span>
							<span class="article-meta">
								{sub?.name} &middot; <FormattedDate date={article.data.pubDate} />
							</span>
						</a>
					</li>
				);
			})}
		</ul>
	) : (
		<p class="empty">No articles yet. Check back soon!</p>
	)}
</BaseLayout>

<style>
	.subcategory-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin: 1.5em 0;
	}
	.subcategory-nav a {
		display: inline-block;
		padding: 0.4em 1em;
		background: rgb(var(--gray-light));
		border-radius: 4px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-size: 0.9em;
	}
	.subcategory-nav a:hover {
		background: var(--accent);
		color: white;
	}
	.article-list {
		list-style: none;
		padding: 0;
	}
	.article-list li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.article-list li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.75em 0;
		text-decoration: none;
		color: rgb(var(--black));
	}
	.article-list li a:hover .article-title {
		color: var(--accent);
	}
	.article-meta {
		color: rgb(var(--gray));
		font-size: 0.85em;
		white-space: nowrap;
		margin-left: 1em;
	}
	.empty {
		color: rgb(var(--gray));
		font-style: italic;
	}
</style>
