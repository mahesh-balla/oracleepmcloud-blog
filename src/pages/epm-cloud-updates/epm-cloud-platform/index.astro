---
import { getCollection } from 'astro:content';
import FormattedDate from '../../../components/FormattedDate.astro';
import { PRODUCTS, SUBCATEGORIES, getSubcategoriesForProduct } from '../../../consts';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const product = PRODUCTS.find((p) => p.slug === 'epm-cloud-updates')!;
const subcategory = SUBCATEGORIES.find((s) => s.slug === 'epm-cloud-platform')!;
const articles = (
	await getCollection(
		'articles',
		({ data }) => data.product === 'epm-cloud-updates' && data.subcategory === 'epm-cloud-platform',
	)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
	title={`${subcategory.name} - ${product.name} - Oracle EPM Cloud Blog`}
	description={`${subcategory.description} for ${product.name}`}
>
	<div class="page-header">
		<nav class="breadcrumb">
			<a href="/">Home</a> <span class="sep">/</span>
			<a href={`/${product.slug}/`}>{product.name}</a> <span class="sep">/</span>
			<span>{subcategory.name}</span>
		</nav>
		<h1>{subcategory.name}</h1>
		<p>{subcategory.description} for {product.name}.</p>
	</div>

	<nav class="subcategory-nav">
		{getSubcategoriesForProduct(product.slug).map((sub) => (
			<a
				href={`/${product.slug}/${sub.slug}/`}
				class:list={['sub-pill', { active: sub.slug === subcategory.slug }]}
			>
				{sub.name}
			</a>
		))}
	</nav>

	{articles.length > 0 ? (
		<ul class="article-list">
			{articles.map((article) => (
				<li>
					<a href={`/${product.slug}/${subcategory.slug}/${article.id}/`}>
						<span class="article-title">{article.data.title}</span>
						<span class="article-meta">
							<FormattedDate date={article.data.pubDate} />
						</span>
					</a>
				</li>
			))}
		</ul>
	) : (
		<div class="empty-state">
			<p>No articles yet in this category. Check back soon!</p>
		</div>
	)}
</BaseLayout>

<style>
	.page-header { margin-bottom: 1.5em; }
	.breadcrumb { font-size: 0.85em; color: var(--oracle-warm-gray); margin-bottom: 0.75em; }
	.breadcrumb a { color: var(--accent); text-decoration: none; }
	.breadcrumb a:hover { text-decoration: underline; }
	.breadcrumb .sep { margin: 0 0.35em; opacity: 0.4; }
	.page-header p { color: var(--oracle-warm-gray); font-size: 1em; margin-top: 0.25em; }
	.subcategory-nav { display: flex; flex-wrap: wrap; gap: 0.5em; margin-bottom: 2em; }
	.sub-pill {
		display: inline-block; padding: 0.45em 1em; background: var(--surface);
		border: 1px solid var(--border); border-radius: 20px; text-decoration: none;
		color: var(--oracle-warm-gray); font-size: 0.88em; font-weight: 500;
		transition: all 0.15s;
	}
	.sub-pill:hover, .sub-pill.active {
		background: var(--accent); color: #fff; border-color: var(--accent);
	}
	.article-list {
		list-style: none; padding: 0; margin: 0; background: var(--surface);
		border-radius: var(--radius-lg); border: 1px solid var(--border); overflow: hidden;
	}
	.article-list li { border-bottom: 1px solid var(--border); }
	.article-list li:last-child { border-bottom: none; }
	.article-list li a {
		display: flex; justify-content: space-between; align-items: center;
		padding: 1em 1.25em; text-decoration: none; color: var(--oracle-charcoal);
		transition: background 0.12s;
	}
	.article-list li a:hover { background: rgba(var(--gray-light), 0.4); }
	.article-list li a:hover .article-title { color: var(--accent); }
	.article-title { font-weight: 500; }
	.article-meta {
		color: var(--oracle-warm-gray); font-size: 0.82em;
		white-space: nowrap; margin-left: 1em;
	}
	.empty-state {
		text-align: center; padding: 3em 1em; background: var(--surface);
		border-radius: var(--radius-lg); border: 1px solid var(--border);
		color: var(--oracle-warm-gray); font-style: italic;
	}
	@media (max-width: 720px) {
		.article-list li a { flex-direction: column; align-items: flex-start; gap: 0.4em; }
		.article-meta { margin-left: 0; }
	}
</style>
