---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { PRODUCTS, SITE_DESCRIPTION, SITE_TITLE, SUBCATEGORIES } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const allArticles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentArticles = allArticles.slice(0, 6);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero-badge">Oracle EPM Cloud</div>
		<h1>Tutorials, Tips &amp; Updates</h1>
		<p>
			Your go-to resource for Oracle EPM Cloud product guidance — from step-by-step tutorials to
			the latest release notes across EPM Cloud Updates, Narrative Reporting, and Planning Cloud.
		</p>
	</section>

	<section class="products">
		<h2>Explore by Product</h2>
		<div class="product-grid">
			{
				PRODUCTS.map((product) => (
					<div class="product-card">
						<div class="card-accent" />
						<h3>
							<a href={`/${product.slug}/`}>{product.name}</a>
						</h3>
						<p>{product.description}</p>
						<ul class="tag-list">
							{SUBCATEGORIES.map((sub) => (
								<li>
									<a href={`/${product.slug}/${sub.slug}/`}>{sub.name}</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</section>

	{
		recentArticles.length > 0 && (
			<section class="recent">
				<h2>Recent Articles</h2>
				<ul class="article-list">
					{recentArticles.map((article) => {
						const product = PRODUCTS.find((p) => p.slug === article.data.product);
						return (
							<li>
								<a href={`/${article.data.product}/${article.data.subcategory}/${article.id}/`}>
									<span class="article-title">{article.data.title}</span>
									<span class="article-meta">
										<span class="article-product">{product?.name}</span>
										<FormattedDate date={article.data.pubDate} />
									</span>
								</a>
							</li>
						);
					})}
				</ul>
			</section>
		)
	}
</BaseLayout>

<style>
	/* Hero */
	.hero {
		text-align: center;
		padding: 2em 0 2.5em;
		margin-bottom: 2em;
	}
	.hero-badge {
		display: inline-block;
		background: var(--accent);
		color: #fff;
		font-size: 0.75em;
		font-weight: 600;
		padding: 0.3em 0.9em;
		border-radius: 20px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin-bottom: 1em;
	}
	.hero h1 {
		font-size: 2.75em;
		margin-bottom: 0.3em;
		color: var(--oracle-charcoal);
	}
	.hero p {
		color: var(--oracle-warm-gray);
		font-size: 1.05em;
		max-width: 640px;
		margin: 0 auto;
		line-height: 1.65;
	}

	/* Products */
	.products {
		margin-bottom: 3em;
	}
	.products h2 {
		text-align: center;
		margin-bottom: 1.25em;
	}
	.product-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5em;
	}
	.product-card {
		position: relative;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 1.75em 1.5em 1.5em;
		background: var(--surface);
		box-shadow: var(--box-shadow);
		transition: box-shadow 0.2s, transform 0.2s;
		overflow: hidden;
	}
	.product-card:hover {
		box-shadow: var(--box-shadow-lg);
		transform: translateY(-2px);
	}
	.card-accent {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: var(--accent);
	}
	.product-card h3 {
		margin: 0 0 0.5em 0;
		font-size: 1.2em;
	}
	.product-card h3 a {
		text-decoration: none;
		color: var(--oracle-charcoal);
	}
	.product-card h3 a:hover {
		color: var(--accent);
	}
	.product-card p {
		color: var(--oracle-warm-gray);
		font-size: 0.88em;
		line-height: 1.55;
	}
	.tag-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}
	.tag-list li a {
		display: inline-block;
		padding: 0.3em 0.7em;
		background: rgba(var(--gray-light), 0.7);
		border-radius: 4px;
		font-size: 0.8em;
		font-weight: 500;
		text-decoration: none;
		color: var(--oracle-warm-gray);
		transition: background 0.15s, color 0.15s;
	}
	.tag-list li a:hover {
		background: var(--accent);
		color: white;
	}

	/* Recent Articles */
	.recent {
		margin-bottom: 2em;
	}
	.recent h2 {
		text-align: center;
		margin-bottom: 1em;
	}
	.article-list {
		list-style: none;
		padding: 0;
		margin: 0;
		background: var(--surface);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border);
		overflow: hidden;
	}
	.article-list li {
		border-bottom: 1px solid var(--border);
	}
	.article-list li:last-child {
		border-bottom: none;
	}
	.article-list li a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1em 1.25em;
		text-decoration: none;
		color: var(--oracle-charcoal);
		transition: background 0.12s;
	}
	.article-list li a:hover {
		background: rgba(var(--gray-light), 0.4);
	}
	.article-list li a:hover .article-title {
		color: var(--accent);
	}
	.article-title {
		font-weight: 500;
	}
	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		color: var(--oracle-warm-gray);
		font-size: 0.82em;
		white-space: nowrap;
		margin-left: 1em;
	}
	.article-product {
		background: rgba(var(--gray-light), 0.7);
		padding: 0.15em 0.55em;
		border-radius: 3px;
		font-size: 0.9em;
		font-weight: 500;
	}
	@media (max-width: 720px) {
		.hero h1 { font-size: 2em; }
		.article-list li a {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.4em;
		}
		.article-meta { margin-left: 0; }
	}
</style>
