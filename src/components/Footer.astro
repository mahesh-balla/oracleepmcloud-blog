---
import { PRODUCTS, SUBCATEGORIES } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-grid">
		{
			PRODUCTS.map((product) => (
				<div class="footer-column">
					<h4>
						<a href={`/${product.slug}/`}>{product.name}</a>
					</h4>
					<ul>
						{SUBCATEGORIES.map((sub) => (
							<li>
								<a href={`/${product.slug}/${sub.slug}/`}>{sub.name}</a>
							</li>
						))}
					</ul>
				</div>
			))
		}
	</div>
	<div class="copyright">
		&copy; {today.getFullYear()} oracleepmcloud.com. All rights reserved.
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 3em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-grid {
		display: flex;
		justify-content: center;
		gap: 3em;
		margin-bottom: 2em;
		text-align: left;
	}
	.footer-column h4 {
		margin-bottom: 0.5em;
		font-size: 1em;
	}
	.footer-column h4 a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.footer-column ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-column li {
		margin-bottom: 0.25em;
	}
	.footer-column a {
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.85em;
	}
	.footer-column a:hover {
		color: var(--accent);
	}
	.copyright {
		font-size: 0.85em;
		border-top: 1px solid rgb(var(--gray-light));
		padding-top: 1em;
	}
	@media (max-width: 720px) {
		.footer-grid {
			flex-direction: column;
			gap: 1.5em;
			align-items: center;
			text-align: center;
		}
	}
</style>
