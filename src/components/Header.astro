---
import { PRODUCTS, SITE_TITLE, SUBCATEGORIES } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="header-inner">
		<nav>
			<a href="/" class="logo">
				<span class="logo-mark">EPM</span>
				<span class="logo-text">Oracle EPM Cloud Blog</span>
			</a>
			<button class="mobile-toggle" aria-label="Toggle navigation" id="nav-toggle">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="3" y1="6" x2="21" y2="6" />
					<line x1="3" y1="12" x2="21" y2="12" />
					<line x1="3" y1="18" x2="21" y2="18" />
				</svg>
			</button>
			<div class="nav-links" id="nav-links">
				<HeaderLink href="/">Home</HeaderLink>
				{
					PRODUCTS.map((product) => (
						<div class="dropdown">
							<HeaderLink href={`/${product.slug}/`}>{product.name}</HeaderLink>
							<div class="dropdown-content">
								{SUBCATEGORIES.map((sub) => (
									<a href={`/${product.slug}/${sub.slug}/`}>{sub.name}</a>
								))}
							</div>
						</div>
					))
				}
			</div>
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById('nav-toggle');
	const links = document.getElementById('nav-links');
	toggle?.addEventListener('click', () => {
		links?.classList.toggle('open');
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: #000000;
		border-bottom: 3px solid var(--accent);
	}
	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 60px;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.6em;
		text-decoration: none;
		color: #fff;
		font-weight: 700;
		font-size: 1em;
		white-space: nowrap;
	}
	.logo-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: var(--accent);
		color: #fff;
		font-size: 0.75em;
		font-weight: 700;
		padding: 0.2em 0.5em;
		border-radius: 4px;
		letter-spacing: 0.05em;
	}
	.logo-text {
		font-size: 0.95em;
	}
	.mobile-toggle {
		display: none;
		background: none;
		border: none;
		color: #fff;
		cursor: pointer;
		padding: 0.25em;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.15em;
	}
	.nav-links :global(a) {
		padding: 0.6em 0.75em;
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		font-size: 0.88em;
		font-weight: 500;
		border-radius: 4px;
		transition: color 0.15s, background 0.15s;
		border-bottom: none;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: #fff;
		background: rgba(255, 255, 255, 0.1);
	}
	.dropdown {
		position: relative;
	}
	.dropdown-content {
		display: none;
		position: absolute;
		top: calc(100% + 4px);
		left: 0;
		background: #fff;
		min-width: 200px;
		border-radius: var(--radius);
		box-shadow: var(--box-shadow-lg);
		border: 1px solid var(--border);
		overflow: hidden;
		z-index: 200;
	}
	.dropdown-content a {
		display: block;
		padding: 0.65em 1em;
		color: var(--oracle-charcoal) !important;
		font-size: 0.88em;
		font-weight: 400;
		background: none !important;
		border-radius: 0 !important;
		transition: background 0.12s, color 0.12s;
	}
	.dropdown-content a:hover {
		background: rgba(var(--gray-light), 0.8) !important;
		color: var(--accent) !important;
	}
	.dropdown:hover .dropdown-content {
		display: block;
	}

	@media (max-width: 860px) {
		.mobile-toggle {
			display: block;
		}
		.nav-links {
			display: none;
			flex-direction: column;
			align-items: stretch;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: #000000;
			border-top: 1px solid rgba(255, 255, 255, 0.1);
			padding: 0.5em 1em 1em;
			box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
		}
		.nav-links.open {
			display: flex;
		}
		.dropdown-content {
			position: static;
			box-shadow: none;
			border: none;
			background: rgba(255, 255, 255, 0.05);
			border-radius: 4px;
			margin-top: 2px;
		}
		.dropdown-content a {
			color: rgba(255, 255, 255, 0.8) !important;
			padding-left: 1.5em;
		}
		.dropdown-content a:hover {
			background: rgba(255, 255, 255, 0.08) !important;
			color: #fff !important;
		}
		.dropdown:hover .dropdown-content {
			display: block;
		}
	}
</style>
